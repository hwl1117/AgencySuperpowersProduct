# VideoBrain 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here

# MiMo API配置（backend-node 使用）
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_URL=https://token-plan-sgp.xiaomimimo.com/v1/chat/completions
MIMO_MODEL=mimo-v2.5-pro

# 数据库配置
DATABASE_URL=sqlite:///./videobrain.db

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0

# 服务配置
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# 文件存储路径
DOWNLOAD_DIR=./downloads
AUDIO_DIR=./audio
KNOWLEDGE_BASE_DIR=./knowledge_base_db

# 日志级别
LOG_LEVEL=INFO

# 视频处理配置
MAX_VIDEO_DURATION=600  # 最大视频时长（秒）
MAX_FILE_SIZE=100MB     # 最大文件大小

# 支持的视频平台
SUPPORTED_PLATFORMS=douyin,kuaishou,bilibili,youtube,tiktok,xiaohongshu